{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "heriheri",
  "version": "1.0.0",
  "identifier": "com.alfred-whitman.heriheri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "heriheri",
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AgainsTurb/HeriHeriCloud/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCNTg4NDMzNjY2NDcxMwpSV1FUUjJZMlE0aTFBUTk5Z1ZFL3FMRFY5TzVVdGo2elVZZzJpYWhldVlCcG8xYkNhQWhacHdNMAo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}